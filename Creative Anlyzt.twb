      <column caption='CPA' datatype='real' name='[Calculation_1454930154799104]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Gross Cost]/[Total Conversions]' />
      </column>
      <column caption='CVR' datatype='real' name='[Calculation_1454930154913793]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Total Conversions]/[Clicks]' />
      </column>
      <column caption='CTR' datatype='real' name='[Calculation_1454930154991618]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Clicks]/[Impressions]' />
      </column>
      <column caption='CPM' datatype='real' name='[Calculation_1454930155057155]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Gross Cost]/[Impressions])*1000' />
      </column>
      <column caption='Viewability Rate' datatype='real' name='[Calculation_1454930155134980]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Viewable Impressions]/[Measurable Impressions]' />
      </column>
      <column caption='vCPM' datatype='real' name='[Calculation_1454930155208709]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Gross Cost]/[Viewable Impressions])*1000' />
      </column>
      <column caption='CPC' datatype='integer' name='[Calculation_1682253498216450]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DIV(SUM(INT([Gross Cost])),SUM([Total Conversions]))' />
